# ============================================
# Nexo Hub — Variables de Entorno
# ============================================

# Database (Panel's own PostgreSQL)
DATABASE_URL=postgresql://admin:CHANGE_ME@localhost:5432/panel_control

# Port
PORT=3100

# CORS
CORS_ORIGINS=http://localhost:4200,https://panel.strategialaboratory.com

# GitHub (for cloning nexo-core into VPS)
MATRIZ_REPO_URL=https://github.com/llorisg-stra/nexo-core.git
GITHUB_PAT=ghp_your_github_personal_access_token

# Supabase (shared or per-matrix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudflare (for automatic DNS)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

# OVH API (for VPS management)
OVH_APP_KEY=your_ovh_app_key
OVH_APP_SECRET=your_ovh_app_secret
OVH_CONSUMER_KEY=your_ovh_consumer_key
OVH_ENDPOINT=ovh-eu
